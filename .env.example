# ===========================================================================
# Configuração de banco de dados
# ===========================================================================

# --- Supabase (produção) ---
# 1. Crie um projeto em https://supabase.com
# 2. Vá em Project Settings → Database → Connection string → URI
# 3. Substitua [YOUR-PASSWORD] pela senha do banco
# 4. Cole a URL completa abaixo
# Nota: "pgbouncer=true" é obrigatório — o pooler em modo transaction (6543)
# não suporta prepared statements, e o Prisma Client falha sem esse parâmetro.
DATABASE_URL="postgresql://postgres.[PROJETO]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: usada apenas pelo Prisma Migrate/db push (schema.prisma tem
# directUrl configurado). O pooler transaction (6543) não suporta os locks
# de sessão exigidos por migrations — use a porta 5432 (session pooler ou
# conexão direta) aqui.
DIRECT_URL="postgresql://postgres.[PROJETO]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:5432/postgres"

# --- Desenvolvimento local com SQLite (alternativa) ---
# Para usar SQLite localmente:
#   1. Troque o provider no prisma/schema.prisma para "sqlite"
#   2. Use a URL abaixo
# DATABASE_URL="file:./dev.db"

# ===========================================================================
# Extração de CI via IA (importação automática, opcional)
# ===========================================================================
# Duas opções, escolhidas em runtime: se OPENROUTER_API_KEY estiver definida,
# ela tem prioridade; senão o endpoint cai para o LM Studio local. Sem nenhuma
# das duas configuradas, a importação automática falha e o usuário preenche
# os campos manualmente (fallback já existente).

# --- OpenRouter (nuvem, funciona em qualquer hospedagem, inclusive Vercel) ---
# 1. Crie uma chave em https://openrouter.ai/settings/keys
# 2. Cole a chave abaixo
# Modelo padrão: google/gemma-4-26b-a4b-it:free (testado e validado para esta
# tarefa). Veja https://openrouter.ai/models?input_modalities=image para
# outras opções gratuitas com suporte a visão, caso este saia do ar/mude.
OPENROUTER_API_KEY="[SUA_CHAVE_AQUI]"
OPENROUTER_MODEL="google/gemma-4-26b-a4b-it:free"

# --- LM Studio (modelo de visão local, gratuito e ilimitado, só para dev) ---
# 1. Instale o LM Studio (https://lmstudio.ai)
# 2. Baixe um modelo com suporte a VISÃO (ex.: Qwen2-VL-7B-Instruct, MiniCPM-V-2.6)
# 3. Na aba "Local Server", carregue o modelo e clique em "Start Server"
# 4. Copie o identificador exato do modelo carregado para LMSTUDIO_MODEL
# Nota: isso só funciona enquanto o LM Studio estiver aberto na máquina que
# roda esta aplicação — não é solução de hospedagem de produção.
LMSTUDIO_BASE_URL="http://localhost:1234/v1"
LMSTUDIO_MODEL="[NOME_DO_MODELO_CARREGADO]"
