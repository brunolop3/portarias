# ===========================================================================
# Configuração de banco de dados
# ===========================================================================

# --- Supabase (produção) ---
# 1. Crie um projeto em https://supabase.com
# 2. Vá em Project Settings → Database → Connection string → URI
# 3. Substitua [YOUR-PASSWORD] pela senha do banco
# 4. Cole a URL completa abaixo
# Nota: "pgbouncer=true" é obrigatório — o pooler em modo transaction (6543)
# não suporta prepared statements, e o Prisma Client falha sem esse parâmetro.
DATABASE_URL="postgresql://postgres.[PROJETO]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: usada apenas pelo Prisma Migrate/db push (schema.prisma tem
# directUrl configurado). O pooler transaction (6543) não suporta os locks
# de sessão exigidos por migrations — use a porta 5432 (session pooler ou
# conexão direta) aqui.
DIRECT_URL="postgresql://postgres.[PROJETO]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:5432/postgres"

# --- Desenvolvimento local com SQLite (alternativa) ---
# Para usar SQLite localmente:
#   1. Troque o provider no prisma/schema.prisma para "sqlite"
#   2. Use a URL abaixo
# DATABASE_URL="file:./dev.db"
